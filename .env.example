# Local default uses SQLite. Vercel/Postgres uses a postgresql:// connection string.
DATABASE_URL=file:../storage/vvviruz-command-center.db
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000

# File storage: local for dev/Docker, vercel-blob for Vercel durable object storage.
ASSET_STORAGE_DRIVER=local
BLOB_READ_WRITE_TOKEN=
BLOB_PREFIX=vvviruz

AUTH_SECRET=replace-with-a-64-character-random-secret
ADMIN_USERNAME=owner
ADMIN_PASSWORD_HASH=replace-with-output-of-npm-run-hash-admin-password
ADMIN_TOTP_ISSUER=vvviruz Command Center
ADMIN_SESSION_TTL_HOURS=12
ADMIN_PREAUTH_TTL_MINUTES=10
EMAIL_PROVIDER=resend
RESEND_API_KEY=replace-with-your-resend-api-key
EMAIL_FROM=vvviruz <updates@example.com>
ADMIN_TEST_EMAIL=you@example.com
EMAIL_POSTAL_ADDRESS=Optional mailing footer line

# Scheduled backups. CRON_SECRET must also be set in Vercel for the cron route.
CRON_SECRET=replace-with-a-random-cron-secret
BACKUP_ENCRYPTION_SECRET=replace-with-a-64-character-random-backup-secret
GOOGLE_DRIVE_BACKUP_ENABLED=0
GOOGLE_DRIVE_AUTH_MODE=oauth
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=http://127.0.0.1:53682/oauth2callback
GOOGLE_DRIVE_OAUTH_SCOPE=https://www.googleapis.com/auth/drive
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_BACKUP_FOLDER_ID=
