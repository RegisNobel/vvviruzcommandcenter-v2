generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id                 String        @id
  username           String        @unique
  totpMethod         String?
  totpEncryptedSecret String?
  totpEnrolledAt     DateTime?
  createdAt          DateTime
  updatedAt          DateTime
  sessions           AuthSession[]

  @@index([username])
}

model AuthSession {
  id                String    @id
  userId            String
  username          String
  stage             String
  factorMethod      String?
  pendingTotpSecret String?
  createdAt         DateTime
  updatedAt         DateTime
  expiresAt         DateTime
  user              AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model Release {
  id               String                 @id
  title            String
  slug             String                 @unique
  pinned           Boolean                @default(false)
  collaborator     Boolean                @default(false)
  collaboratorName String                 @default("")
  upc              String                 @default("")
  isrc             String                 @default("")
  coverArtId       String?
  coverArtFileName String?
  coverArtUrl      String?
  coverArtPath     String                 @default("")
  coverArtMimeType String?
  lyrics           String                 @default("")
  type             String                 @default("nerdcore")
  releaseDate      DateTime?
  conceptDetails   String                 @default("")
  publicDescription String                @default("")
  publicLongDescription String            @default("")
  seoTitle         String                 @default("")
  metaDescription  String                 @default("")
  coverArtAltText  String                 @default("")
  socialShareTitle String                 @default("")
  socialShareDescription String           @default("")
  spotifyUrl       String                 @default("")
  appleMusicUrl    String                 @default("")
  youtubeUrl       String                 @default("")
  isPublished      Boolean                @default(false)
  isFeatured       Boolean                @default(false)
  featuredVideoUrl String                 @default("")
  publicLyricsEnabled Boolean             @default(false)
  conceptComplete  Boolean                @default(false)
  beatMade         Boolean                @default(false)
  lyricsFinished   Boolean                @default(false)
  recorded         Boolean                @default(false)
  mixMastered      Boolean                @default(false)
  published        Boolean                @default(false)
  createdOn        DateTime
  updatedOn        DateTime
  tasks            ReleaseTask[]
  streamingLinks   ReleaseStreamingLink[]
  copies           CopyEntry[]
  categories       ReleaseCategoryAssignment[]
  adImportBatches  AdImportBatch[]
  adCreativeReports AdCreativeReport[]
  adCampaignLearnings AdCampaignLearning[]
  shortLinks       ShortLink[]
  linkHubs         LinkHub[]
  featuredPlaylists Playlist[]        @relation("PlaylistFeaturedRelease")
  playlists         PlaylistRelease[]

  @@index([pinned, updatedOn])
  @@index([isPublished, releaseDate])
  @@index([isFeatured, releaseDate])
}

model ReleaseCategory {
  id          String                      @id
  name        String
  slug        String                      @unique
  description String                      @default("")
  sortOrder   Int                         @default(0)
  createdAt   DateTime
  updatedAt   DateTime
  releases    ReleaseCategoryAssignment[]

  @@index([sortOrder, name])
}

model ReleaseCategoryAssignment {
  id         String          @id
  categoryId String
  releaseId  String
  sortOrder  Int             @default(0)
  createdAt  DateTime
  updatedAt  DateTime
  category   ReleaseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  release    Release         @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([categoryId, releaseId])
  @@index([releaseId])
  @@index([categoryId, sortOrder])
}

model ReleaseTask {
  id        String   @id
  releaseId String
  text      String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime
  updatedAt DateTime
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId, sortOrder])
}

model ReleaseStreamingLink {
  id        String   @id
  releaseId String
  platform  String
  url       String
  createdAt DateTime
  updatedAt DateTime
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, platform])
  @@index([releaseId])
}

model CopyEntry {
  id            String   @id
  releaseId     String?
  hook          String
  caption       String
  type          String   @default("discovery-shock")
  hookType      String   @default("discovery-shock")
  contentType   String   @default("amv-lyric-edit")
  songSection   String   @default("hook")
  creativeNotes String   @default("")
  createdOn     DateTime
  updatedOn     DateTime
  archivedAt    DateTime?
  archiveReason String?
  release       Release? @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  adLinks       AdCreativeCopyLink[]

  @@index([releaseId])
  @@index([hookType, contentType, songSection])
  @@index([updatedOn])
}

model AdImportBatch {
  id                 String               @id
  source             String               @default("meta")
  name               String               @default("")
  releaseId          String?
  reportingStart     DateTime?
  reportingEnd       DateTime?
  exportedAt         DateTime?
  attributionSetting String               @default("7-day click, 1-day view, 1-day engagement")
  batchType          String               @default("Rolling Snapshot")
  fileNames          String               @default("[]")
  notes              String               @default("")
  createdAt          DateTime
  updatedAt          DateTime
  release            Release?             @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  reports            AdCreativeReport[]
  learnings          AdCampaignLearning[]

  @@index([releaseId])
  @@index([createdAt])
  @@index([exportedAt])
  @@index([batchType])
}

model AdCreativeReport {
  id                     String               @id
  importBatchId          String
  releaseId              String?
  campaignName           String?
  adSetName              String?
  adName                 String
  adDelivery             String?
  reportingStart         DateTime?
  reportingEnd           DateTime?
  spend                  Float?
  impressions            Int?
  reach                  Int?
  frequency              Float?
  costPerThousandAccountsReached Float?
  cpm                    Float?
  results                Float?
  resultIndicator        String?
  costPerResult          Float?
  linkClicks             Int?
  cpc                    Float?
  ctr                    Float?
  clicksAll              Int?
  ctrAll                 Float?
  cpcAll                 Float?
  landingPageViews       Int?
  costPerLandingPageView Float?
  shopClicks             Int?
  pageEngagement         Int?
  postReactions          Int?
  postComments           Int?
  postSaves              Int?
  postShares             Int?
  facebookLikes          Int?
  instagramFollows       Int?
  videoPlays             Int?
  twoSecondContinuousPlays Int?
  costPerTwoSecondContinuousPlay Float?
  threeSecondPlays       Int?
  costPerThreeSecondPlay Float?
  thruPlays              Int?
  costPerThruPlay        Float?
  video25                Int?
  video50                Int?
  video75                Int?
  video95                Int?
  video100               Int?
  qualityRanking         String?
  engagementRateRanking  String?
  conversionRateRanking  String?
  utmSource              String?
  utmCampaign            String?
  utmContent             String?
  createdAt              DateTime
  updatedAt              DateTime
  importBatch            AdImportBatch         @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  release                Release?              @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  copyLinks              AdCreativeCopyLink[]

  @@index([importBatchId])
  @@index([releaseId])
  @@index([utmSource, utmCampaign, utmContent])
  @@index([adName, adSetName, reportingStart, reportingEnd])
}

model AdCreativeCopyLink {
  id                 String           @id
  adCreativeReportId String
  copyEntryId        String
  createdAt          DateTime
  adCreativeReport   AdCreativeReport @relation(fields: [adCreativeReportId], references: [id], onDelete: Cascade)
  copyEntry          CopyEntry        @relation(fields: [copyEntryId], references: [id], onDelete: Cascade)

  @@unique([adCreativeReportId, copyEntryId])
  @@index([copyEntryId])
}

model AdCampaignLearning {
  id                 String        @id
  importBatchId      String
  releaseId          String?
  summary            String        @default("")
  whatWorked         String        @default("")
  whatFailed         String        @default("")
  nextTest           String        @default("")
  decision           String        @default("iterate")
  reviewedAt         DateTime?
  reviewedBy         String        @default("")
  finalDecision      String        @default("")
  humanOverrideNotes String        @default("")
  createdAt          DateTime
  updatedAt          DateTime
  importBatch        AdImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  release            Release?      @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([importBatchId])
  @@index([releaseId])
  @@index([updatedAt])
}

model SiteSettings {
  id             String   @id
  artistName     String   @default("vvviruz")
  tagline        String   @default("")
  shortBio       String   @default("")
  longBio        String   @default("")
  contactEmail   String   @default("")
  bookingEmail   String   @default("")
  socialLinks    String   @default("[]")
  heroText       String   @default("")
  aboutContent   String   @default("")
  linksPageItems String   @default("[]")
  siteContent    String   @default("{}")
  createdOn      DateTime
  updatedOn      DateTime
}

model Subscriber {
  id               String         @id
  name             String         @default("")
  email            String         @unique
  source           String         @default("exclusive")
  status           String         @default("active")
  consentGiven     Boolean        @default(false)
  downloadToken    String         @unique
  unsubscribeToken String         @unique
  createdAt        DateTime
  updatedAt        DateTime
  unsubscribedAt   DateTime?
  // Source attribution (V1 - first-source preserved on upsert)
  sourceUtmSource     String      @default("")
  sourceUtmMedium     String      @default("")
  sourceUtmCampaign   String      @default("")
  sourceUtmContent    String      @default("")
  sourceUtmTerm       String      @default("")
  sourceReferrer      String      @default("")
  sourceLandingPage   String      @default("")
  sourceOfferMode     String      @default("")
  sourceOfferName     String      @default("")
  sourceSignupContext String      @default("")
  sendLogs         EmailSendLog[]

  @@index([status, createdAt])
  @@index([source, status])
  @@index([sourceUtmCampaign])
  @@index([sourceOfferMode])
}

model EmailCampaign {
  id             String         @id
  subject        String
  previewText    String         @default("")
  body           String         @default("")
  ctaLabel       String         @default("")
  ctaUrl         String         @default("")
  audienceFilter String         @default("all_active")
  status         String         @default("draft")
  recipientCount Int            @default(0)
  sentAt         DateTime?
  createdAt      DateTime
  updatedAt      DateTime
  sendLogs       EmailSendLog[]

  @@index([status, createdAt])
}

model EmailSendLog {
  id                String        @id
  campaignId        String
  subscriberId      String?
  email             String
  status            String
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime
  campaign          EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriber        Subscriber?   @relation(fields: [subscriberId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([subscriberId])
  @@index([status, createdAt])
}
model AnalyticsEvent {
  id          String   @id
  eventType   String
  page        String
  path        String   @default("")
  hubPath     String   @default("")
  releaseId   String?
  linkType    String   @default("")
  linkLabel   String   @default("")
  targetUrl   String   @default("")
  referrer    String   @default("")
  userAgent   String   @default("")
  visitorId   String   @default("")
  sessionId   String   @default("")
  utmSource   String   @default("")
  utmMedium   String   @default("")
  utmCampaign String   @default("")
  utmContent  String   @default("")
  utmTerm     String   @default("")
  country     String   @default("")
  createdAt   DateTime

  @@index([page, createdAt])
  @@index([eventType, createdAt])
  @@index([releaseId, createdAt])
  @@index([visitorId, createdAt])
}

model PublicRateLimit {
  id              String    @id
  bucket          String
  key             String
  count           Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  updatedAt       DateTime

  @@unique([bucket, key])
  @@index([bucket, updatedAt])
  @@index([blockedUntil])
}

model BackupRun {
  id                  String    @id
  type                String
  status              String
  destination         String    @default("")
  blobPath            String    @default("")
  googleDriveFileId   String?
  googleDriveFolderId String?
  sizeBytes           Int?
  checksumSha256      String?
  recordCounts        String    @default("{}")
  errorMessage        String?
  startedAt           DateTime
  finishedAt          DateTime?
  createdAt           DateTime

  @@index([type, startedAt])
  @@index([status, startedAt])
}

model ShortLink {
  id             String    @id
  slug           String    @unique
  destinationUrl String    @map("destination_url")
  releaseId      String?   @map("release_id")
  campaignLabel  String    @default("") @map("campaign_label")
  contentLabel   String    @default("") @map("content_label")
  status         String    @default("ACTIVE")
  clickCount     Int       @default(0) @map("click_count")
  createdAt      DateTime  @map("created_at")
  updatedAt      DateTime  @map("updated_at")
  archivedAt     DateTime? @map("archived_at")
  pausedAt       DateTime? @map("paused_at")
  destinationUpdatedAt DateTime? @map("destination_updated_at")
  deletedAt      DateTime? @map("deleted_at")
  release        Release?  @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([releaseId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("short_links")
}

model AppearsOn {
  id            String   @id
  title         String
  artists       String
  coverArtUrl   String
  spotifyUrl    String
  appleMusicUrl String   @default("")
  youtubeMusicUrl String @default("")
  youtubeUrl    String   @default("")
  isPublished   Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime
  updatedAt     DateTime

  @@index([isPublished, sortOrder])
}

model CommissionRequest {
  id               String   @id
  name             String
  email            String
  requestType      String
  budgetRange      String
  deadline         String
  specificDeadline String   @default("")
  topic            String
  beatLink         String   @default("")
  referenceLink    String   @default("")
  usageIntent      String
  additionalNotes  String   @default("")
  status           String   @default("New")
  quotedPrice      String   @default("")
  paypalLink       String   @default("")
  adminNotes       String   @default("")
  deliveryLink     String   @default("")
  
  // Attribution
  utmSource        String   @default("")
  utmMedium        String   @default("")
  utmCampaign      String   @default("")
  utmContent       String   @default("")
  utmTerm          String   @default("")
  referrer         String   @default("")
  landingPage      String   @default("")

  createdAt        DateTime
  updatedAt        DateTime

  @@index([status, createdAt])
}

model LinkHub {
  id              String   @id
  path            String   @unique
  releaseId       String?
  isEnabled       Boolean  @default(true)
  showInPublicNav Boolean  @default(false)
  label           String?
  sortOrder       Int      @default(0)
  createdAt       DateTime
  updatedAt       DateTime
  release         Release? @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([releaseId])
}

model Playlist {
  id                 String            @id
  name               String
  slug               String            @unique
  description        String            @default("")
  coverImageUrl      String            @default("")
  spotifyPlaylistUrl String            @default("")
  applePlaylistUrl   String            @default("")
  youtubePlaylistUrl   String            @default("")
  primaryPlatform    String            @default("spotify")
  featuredReleaseId  String?
  isPublic           Boolean           @default(false)
  isArchived         Boolean           @default(false)
  sortOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  featuredRelease    Release?          @relation("PlaylistFeaturedRelease", fields: [featuredReleaseId], references: [id], onDelete: SetNull)
  releases           PlaylistRelease[]

  @@index([featuredReleaseId])
  @@index([isPublic, isArchived])
  @@index([sortOrder])
}

model PlaylistRelease {
  playlistId       String
  releaseId        String
  position         Int      @default(0)
  spotifyTargetUrl  String   @default("")
  spotifyTrackUrl   String   @default("")
  spotifyTargetMode String   @default("manual")
  appleTargetUrl    String   @default("")
  youtubeTargetUrl  String   @default("")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  release  Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@id([playlistId, releaseId])
  @@index([playlistId, position])
  @@index([releaseId])
}

