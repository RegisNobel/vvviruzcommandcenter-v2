generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id                 String        @id
  username           String        @unique
  totpMethod         String?
  totpEncryptedSecret String?
  totpEnrolledAt     DateTime?
  createdAt          DateTime
  updatedAt          DateTime
  sessions           AuthSession[]

  @@index([username])
}

model AuthSession {
  id                String    @id
  userId            String
  username          String
  stage             String
  factorMethod      String?
  pendingTotpSecret String?
  createdAt         DateTime
  updatedAt         DateTime
  expiresAt         DateTime
  user              AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model Release {
  id               String                 @id
  title            String
  slug             String                 @unique
  pinned           Boolean                @default(false)
  collaborator     Boolean                @default(false)
  collaboratorName String                 @default("")
  upc              String                 @default("")
  isrc             String                 @default("")
  coverArtId       String?
  coverArtFileName String?
  coverArtUrl      String?
  coverArtPath     String                 @default("")
  coverArtMimeType String?
  lyrics           String                 @default("")
  type             String                 @default("nerdcore")
  releaseDate      DateTime?
  conceptDetails   String                 @default("")
  publicDescription String                @default("")
  publicLongDescription String            @default("")
  spotifyUrl       String                 @default("")
  appleMusicUrl    String                 @default("")
  youtubeUrl       String                 @default("")
  isPublished      Boolean                @default(false)
  isFeatured       Boolean                @default(false)
  featuredVideoUrl String                 @default("")
  publicLyricsEnabled Boolean             @default(false)
  conceptComplete  Boolean                @default(false)
  beatMade         Boolean                @default(false)
  lyricsFinished   Boolean                @default(false)
  recorded         Boolean                @default(false)
  mixMastered      Boolean                @default(false)
  published        Boolean                @default(false)
  createdOn        DateTime
  updatedOn        DateTime
  tasks            ReleaseTask[]
  streamingLinks   ReleaseStreamingLink[]
  projects         LyricProject[]
  copies           CopyEntry[]
  categories       ReleaseCategoryAssignment[]
  adImportBatches  AdImportBatch[]
  adCreativeReports AdCreativeReport[]
  adCampaignLearnings AdCampaignLearning[]

  @@index([pinned, updatedOn])
  @@index([isPublished, releaseDate])
  @@index([isFeatured, releaseDate])
}

model ReleaseCategory {
  id          String                      @id
  name        String
  slug        String                      @unique
  description String                      @default("")
  sortOrder   Int                         @default(0)
  createdAt   DateTime
  updatedAt   DateTime
  releases    ReleaseCategoryAssignment[]

  @@index([sortOrder, name])
}

model ReleaseCategoryAssignment {
  id         String          @id
  categoryId String
  releaseId  String
  sortOrder  Int             @default(0)
  createdAt  DateTime
  updatedAt  DateTime
  category   ReleaseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  release    Release         @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([categoryId, releaseId])
  @@index([releaseId])
  @@index([categoryId, sortOrder])
}

model ReleaseTask {
  id        String   @id
  releaseId String
  text      String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime
  updatedAt DateTime
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId, sortOrder])
}

model ReleaseStreamingLink {
  id        String   @id
  releaseId String
  platform  String
  url       String
  createdAt DateTime
  updatedAt DateTime
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, platform])
  @@index([releaseId])
}

model LyricProject {
  id                    String      @id
  title                 String
  releaseId             String?
  audioJson             String?
  backgroundJson        String
  lyricsJson            String
  animationStyle        String
  aspectRatio           String
  lyricPlacementJson    String
  resolution            String
  transcriptionLanguage String
  workflowStep          String
  transcriptionStatus   String
  createdAt             DateTime
  updatedAt             DateTime
  release               Release?    @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  lines                 LyricLine[]

  @@index([releaseId])
  @@index([updatedAt])
}

model LyricLine {
  id        String       @id
  projectId String
  text      String
  startMs   Int
  endMs     Int
  sortOrder Int          @default(0)
  project   LyricProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}

model CopyEntry {
  id            String   @id
  releaseId     String?
  hook          String
  caption       String
  type          String   @default("discovery-shock")
  hookType      String   @default("discovery-shock")
  contentType   String   @default("amv-lyric-edit")
  songSection   String   @default("hook")
  creativeNotes String   @default("")
  createdOn     DateTime
  updatedOn     DateTime
  release       Release? @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  adLinks       AdCreativeCopyLink[]

  @@index([releaseId])
  @@index([hookType, contentType, songSection])
  @@index([updatedOn])
}

model AdImportBatch {
  id                 String               @id
  source             String               @default("meta")
  name               String               @default("")
  releaseId          String?
  reportingStart     DateTime?
  reportingEnd       DateTime?
  exportedAt         DateTime?
  attributionSetting String               @default("7-day click, 1-day view, 1-day engagement")
  batchType          String               @default("Rolling Snapshot")
  fileNames          String               @default("[]")
  notes              String               @default("")
  createdAt          DateTime
  updatedAt          DateTime
  release            Release?             @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  reports            AdCreativeReport[]
  learnings          AdCampaignLearning[]

  @@index([releaseId])
  @@index([createdAt])
  @@index([exportedAt])
  @@index([batchType])
}

model AdCreativeReport {
  id                     String               @id
  importBatchId          String
  releaseId              String?
  campaignName           String?
  adSetName              String?
  adName                 String
  adDelivery             String?
  reportingStart         DateTime?
  reportingEnd           DateTime?
  spend                  Float?
  impressions            Int?
  reach                  Int?
  results                Float?
  costPerResult          Float?
  linkClicks             Int?
  cpc                    Float?
  ctr                    Float?
  pageEngagement         Int?
  postReactions          Int?
  postComments           Int?
  postSaves              Int?
  postShares             Int?
  instagramFollows       Int?
  videoPlays             Int?
  threeSecondPlays       Int?
  thruPlays              Int?
  costPerThruPlay        Float?
  video25                Int?
  video50                Int?
  video75                Int?
  video95                Int?
  video100               Int?
  qualityRanking         String?
  engagementRateRanking  String?
  conversionRateRanking  String?
  utmSource              String?
  utmCampaign            String?
  utmContent             String?
  createdAt              DateTime
  updatedAt              DateTime
  importBatch            AdImportBatch         @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  release                Release?              @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  copyLinks              AdCreativeCopyLink[]

  @@index([importBatchId])
  @@index([releaseId])
  @@index([utmSource, utmCampaign, utmContent])
  @@index([adName, adSetName, reportingStart, reportingEnd])
}

model AdCreativeCopyLink {
  id                 String           @id
  adCreativeReportId String
  copyEntryId        String
  createdAt          DateTime
  adCreativeReport   AdCreativeReport @relation(fields: [adCreativeReportId], references: [id], onDelete: Cascade)
  copyEntry          CopyEntry        @relation(fields: [copyEntryId], references: [id], onDelete: Cascade)

  @@unique([adCreativeReportId, copyEntryId])
  @@index([copyEntryId])
}

model AdCampaignLearning {
  id            String        @id
  importBatchId String
  releaseId     String?
  summary       String        @default("")
  whatWorked    String        @default("")
  whatFailed    String        @default("")
  nextTest      String        @default("")
  decision      String        @default("iterate")
  createdAt     DateTime
  updatedAt     DateTime
  importBatch   AdImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  release       Release?      @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([importBatchId])
  @@index([releaseId])
  @@index([updatedAt])
}

model SiteSettings {
  id             String   @id
  artistName     String   @default("vvviruz")
  tagline        String   @default("")
  shortBio       String   @default("")
  longBio        String   @default("")
  contactEmail   String   @default("")
  bookingEmail   String   @default("")
  socialLinks    String   @default("[]")
  heroText       String   @default("")
  aboutContent   String   @default("")
  linksPageItems String   @default("[]")
  siteContent    String   @default("{}")
  createdOn      DateTime
  updatedOn      DateTime
}

model Subscriber {
  id               String         @id
  name             String         @default("")
  email            String         @unique
  source           String         @default("exclusive")
  status           String         @default("active")
  consentGiven     Boolean        @default(false)
  downloadToken    String         @unique
  unsubscribeToken String         @unique
  createdAt        DateTime
  updatedAt        DateTime
  unsubscribedAt   DateTime?
  sendLogs         EmailSendLog[]

  @@index([status, createdAt])
  @@index([source, status])
}

model EmailCampaign {
  id             String         @id
  subject        String
  previewText    String         @default("")
  body           String         @default("")
  ctaLabel       String         @default("")
  ctaUrl         String         @default("")
  audienceFilter String         @default("all_active")
  status         String         @default("draft")
  recipientCount Int            @default(0)
  sentAt         DateTime?
  createdAt      DateTime
  updatedAt      DateTime
  sendLogs       EmailSendLog[]

  @@index([status, createdAt])
}

model EmailSendLog {
  id                String        @id
  campaignId        String
  subscriberId      String?
  email             String
  status            String
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime
  campaign          EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriber        Subscriber?   @relation(fields: [subscriberId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([subscriberId])
  @@index([status, createdAt])
}
model AnalyticsEvent {
  id          String   @id
  eventType   String
  page        String
  path        String   @default("")
  releaseId   String?
  linkType    String   @default("")
  linkLabel   String   @default("")
  targetUrl   String   @default("")
  referrer    String   @default("")
  userAgent   String   @default("")
  visitorId   String   @default("")
  sessionId   String   @default("")
  utmSource   String   @default("")
  utmMedium   String   @default("")
  utmCampaign String   @default("")
  utmContent  String   @default("")
  utmTerm     String   @default("")
  country     String   @default("")
  createdAt   DateTime

  @@index([page, createdAt])
  @@index([eventType, createdAt])
  @@index([releaseId, createdAt])
  @@index([visitorId, createdAt])
}

model PublicRateLimit {
  id              String    @id
  bucket          String
  key             String
  count           Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  updatedAt       DateTime

  @@unique([bucket, key])
  @@index([bucket, updatedAt])
  @@index([blockedUntil])
}

model BackupRun {
  id                  String    @id
  type                String
  status              String
  destination         String    @default("")
  blobPath            String    @default("")
  googleDriveFileId   String?
  googleDriveFolderId String?
  sizeBytes           Int?
  checksumSha256      String?
  recordCounts        String    @default("{}")
  errorMessage        String?
  startedAt           DateTime
  finishedAt          DateTime?
  createdAt           DateTime

  @@index([type, startedAt])
  @@index([status, startedAt])
}
